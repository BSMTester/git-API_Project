pipeline{
	agent: any

	stages{
		stage('Build'){
		steps{
			echo 'Building....'
		}
		}

		stage('Test'){
		steps{
			echo 'Running Tests....'
		}
		}
	}

	post {
		success{
			githubNotify context:
		'Jenkins CI', 'SUCCESS'
		}
		failure{
			githubNotify context:
		'Jenkins CI', 'FAILURE'
		}
	}
}
